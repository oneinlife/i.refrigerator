# ========================================
# i.refrigerator - Client-side Configuration
# ========================================

# ВАЖНО: Эти настройки больше НЕ ИСПОЛЬЗУЮТСЯ!
# Приложение теперь полностью клиентское.
# 
# Все настройки задаются через UI:
# 1. Откройте http://localhost:3000
# 2. Нажмите "⚙️ Настройки"
# 3. Введите Client ID и Spreadsheet ID
# 4. Сохраните
#
# Данные будут сохранены в localStorage браузера.

# ========================================
# Для старой серверной архитектуры (не используется)
# ========================================

# Google Service Account Credentials (JSON в одну строку)
# GOOGLE_CREDENTIALS={"type":"service_account","project_id":"..."}

# ID вашей Google таблицы
# SPREADSHEET_ID=your_spreadsheet_id_here

# Название листа в таблице
# SHEET_NAME=Inventory

# Автоматическая синхронизация
# AUTO_SYNC=true

# Интервал синхронизации в минутах
# SYNC_INTERVAL=5

# ========================================
# Новая клиентская архитектура
# ========================================
#
# Настройки теперь хранятся в localStorage:
# - google_client_id
# - google_spreadsheet_id
# - google_sheet_name
# - auto_sync_enabled
# - sync_interval_minutes
#
# Используйте UI для настройки!
